{
  "template_id": "dynamic_warmup_v1",
  "name": "Dynamic Warmup",
  "goal": "Prepare the body for throwing and training with progressive movement complexity",
  "duration_min": 12,
  "sequence": [
    {
      "block_name": "Get Moving",
      "exercises": [
        {"name": "Break a sweat", "prescription": "10 yards light jog/skip"},
        {"name": "Mini A's forward", "prescription": "down and back"},
        {"name": "Mini A's lateral", "prescription": "down and back"},
        {"name": "Heel/toe arm circle small", "prescription": "down and back"},
        {"name": "Heel/toe arm circle big", "prescription": "down and back"}
      ]
    },
    {
      "block_name": "Lunge Complex",
      "exercises": [
        {"name": "Lunge to adductor — T-spine rotation — hammy — hip flexor", "prescription": "down"},
        {"name": "Lunge to RDL", "prescription": "down"},
        {"name": "Inch worm step through", "prescription": "back"}
      ]
    },
    {
      "block_name": "Dynamic Movement",
      "exercises": [
        {"name": "Focus bear crawl", "prescription": "down and back"},
        {"name": "A skip (forward then backward)", "prescription": "down and back"},
        {"name": "A skip side to side", "prescription": "down and back"},
        {"name": "Swing over gate (walk forward, plyo backward)", "prescription": "down and back"}
      ]
    },
    {
      "block_name": "Ground-Based Mobility",
      "exercises": [
        {"name": "Frogger cat camel", "prescription": "1x10"},
        {"name": "Frogger thread needle", "prescription": "1x10"},
        {"name": "Bridge reach across", "prescription": "1x10"}
      ]
    },
    {
      "block_name": "Activation — Option 1 (Cuff Focus)",
      "exercises": [
        {"exercise_id": "ex_066", "name": "Driveline Cuff Swingers", "prescription": "1x10 each direction"},
        {"exercise_id": "ex_067", "name": "Flip Ups", "prescription": "1x30"},
        {"exercise_id": "ex_068", "name": "Ball Drops", "prescription": "1x30"},
        {"exercise_id": "ex_069", "name": "Fingertip Drops", "prescription": "1x10 each finger"},
        {"exercise_id": "ex_044", "name": "Shaker Ball Series", "prescription": "2 cycles"}
      ]
    },
    {
      "block_name": "Activation — Option 2 (Scap Focus)",
      "note": "Alternative to Option 1 — choose one per day",
      "exercises": [
        {"exercise_id": "ex_080", "name": "Scap Retraction", "prescription": "1x10"},
        {"exercise_id": "ex_080", "name": "Scap T", "prescription": "1x10"},
        {"exercise_id": "ex_080", "name": "Scap 9090", "prescription": "1x10"},
        {"name": "PNF Pec Fly", "prescription": "1x10"},
        {"exercise_id": "ex_071", "name": "Pronator Pressout", "prescription": "1x10"},
        {"name": "Tricep Kickback", "prescription": "1x10"}
      ]
    },
    {
      "block_name": "Additional Band Addons — Flexor Prime (optional)",
      "note": "Extra FPM priming before throwing, especially for pitchers with UCL history",
      "exercises": [
        {"exercise_id": "ex_071", "name": "Pronator Pressout", "prescription": "1x10"},
        {"exercise_id": "ex_041", "name": "Full Pronation", "prescription": "1x10"},
        {"exercise_id": "ex_070", "name": "Flexor Pressout", "prescription": "1x10"}
      ]
    }
  ],
  "source_notes": "From The Program xlsx — Dynamic Warmup sheet + Landon Starters xlsx additions"
}
