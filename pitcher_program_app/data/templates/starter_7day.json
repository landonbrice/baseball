{
  "$schema": "rotation_template",
  "$description": "Base lifting template for a 7-day rotation starter. Day 0 = game day. Bot adjusts exercises, volume, and intensity based on individual pitcher context.",
  "template_id": "starter_7day_v1",
  "role": "starter",
  "rotation_length": 7,
  "days": {
    "day_0": {
      "label": "Game Day",
      "body_focus": "none",
      "training_intent": "none",
      "lifting": null,
      "recovery": {
        "protocol": "post_outing",
        "activities": [
          { "type": "flush_work", "description": "Light band work, arm circles, gentle ROM", "duration_min": 10 },
          { "type": "nutrition", "description": "Protein + carb intake within 30 min", "priority": "high" },
          { "type": "sleep", "description": "Target 8+ hours", "priority": "critical" }
        ],
        "avoid": ["ice_on_arm_unless_acute_injury", "NSAIDs", "heavy_stretching"]
      },
      "throwing": "game_outing",
      "notes": "No lifting. Focus on fueling and sleep. Log pitch count, arm feel (1-5), and any flags."
    },
    "day_1": {
      "label": "Day After — Active Recovery",
      "body_focus": "full",
      "training_intent": "recovery_flush",
      "lifting": {
        "duration_min": 25,
        "structure": "circuit",
        "blocks": [
          {
            "block_name": "Arm Care",
            "exercises": [
              { "exercise_id": "ex_041", "prescription_mode": "endurance", "notes": "Light, high rep — blood flow to FPM" },
              { "exercise_id": "ex_039", "prescription_mode": "endurance" },
              { "exercise_id": "ex_032", "prescription_mode": "endurance" }
            ]
          },
          {
            "block_name": "Light Movement",
            "exercises": [
              { "exercise_id": "ex_007", "prescription_mode": "hypertrophy", "override": { "sets": 2, "reps": "10", "intensity": "light" } },
              { "exercise_id": "ex_036", "prescription_mode": "endurance" }
            ]
          }
        ]
      },
      "recovery": {
        "protocol": "day_1_recovery",
        "activities": [
          { "type": "soft_tissue", "description": "Foam roll lats, pecs, posterior shoulder", "duration_min": 10 },
          { "type": "mobility", "description": "T-spine rotation, hip 90/90, sleeper stretch", "duration_min": 10 }
        ]
      },
      "throwing": "none_or_light_catch",
      "notes": "Minimal CNS load. Goal is blood flow and movement quality. If arm feel < 3, skip lifting entirely."
    },
    "day_2": {
      "label": "Lower Body — Power Focus",
      "body_focus": "lower",
      "training_intent": "power_development",
      "lifting": {
        "duration_min": 50,
        "structure": "sequential",
        "blocks": [
          {
            "block_name": "Dynamic Warmup",
            "exercises": [
              { "exercise_id": "ex_009", "prescription_mode": "warmup" },
              { "exercise_id": "ex_095", "prescription_mode": "warmup" }
            ]
          },
          {
            "block_name": "Power",
            "exercises": [
              { "exercise_id": "ex_014", "prescription_mode": "power", "notes": "3-4 sets x 4-6 throws each side, max intent" },
              { "exercise_id": "ex_018", "prescription_mode": "power" }
            ]
          },
          {
            "block_name": "Strength",
            "exercises": [
              { "exercise_id": "ex_001", "prescription_mode": "strength", "notes": "Primary lower body compound" },
              { "exercise_id": "ex_005", "prescription_mode": "hypertrophy" }
            ]
          },
          {
            "block_name": "Accessories + Arm Care",
            "exercises": [
              { "exercise_id": "ex_013", "prescription_mode": "strength" },
              { "exercise_id": "ex_041", "prescription_mode": "strength" },
              { "exercise_id": "ex_039", "prescription_mode": "endurance" }
            ]
          }
        ]
      },
      "recovery": null,
      "throwing": "light_long_toss_or_flat_ground",
      "notes": "Biggest training day of the week. Power first, then strength. If WHOOP recovery < 33%, drop to hypertrophy rep ranges and reduce power volume."
    },
    "day_3": {
      "label": "Upper Body — Pull Emphasis",
      "body_focus": "upper",
      "training_intent": "strength_maintenance",
      "lifting": {
        "duration_min": 45,
        "structure": "sequential",
        "blocks": [
          {
            "block_name": "Power",
            "exercises": [
              { "exercise_id": "ex_016", "prescription_mode": "power" }
            ]
          },
          {
            "block_name": "Strength — Pull Dominant",
            "exercises": [
              { "exercise_id": "ex_019", "prescription_mode": "strength" },
              { "exercise_id": "ex_020", "prescription_mode": "hypertrophy" },
              { "exercise_id": "ex_023", "prescription_mode": "endurance" }
            ]
          },
          {
            "block_name": "Push (Conservative)",
            "exercises": [
              { "exercise_id": "ex_025", "prescription_mode": "hypertrophy", "notes": "Moderate load — maintain pressing strength without overloading anterior shoulder" },
              { "exercise_id": "ex_026", "prescription_mode": "hypertrophy" }
            ]
          },
          {
            "block_name": "Arm Care + Core",
            "exercises": [
              { "exercise_id": "ex_045", "prescription_mode": "strength" },
              { "exercise_id": "ex_032", "prescription_mode": "endurance" },
              { "exercise_id": "ex_041", "prescription_mode": "strength" }
            ]
          }
        ]
      },
      "recovery": null,
      "throwing": "bullpen_or_long_toss",
      "notes": "Pull:push ratio should be ~2:1. If shoulder feels tight, drop pressing and add more scapular work."
    },
    "day_4": {
      "label": "Lower Body — Strength Focus",
      "body_focus": "lower",
      "training_intent": "strength_development",
      "lifting": {
        "duration_min": 45,
        "structure": "sequential",
        "blocks": [
          {
            "block_name": "Power",
            "exercises": [
              { "exercise_id": "ex_017", "prescription_mode": "power" }
            ]
          },
          {
            "block_name": "Strength",
            "exercises": [
              { "exercise_id": "ex_002", "prescription_mode": "strength" },
              { "exercise_id": "ex_003", "prescription_mode": "hypertrophy" }
            ]
          },
          {
            "block_name": "Accessories",
            "exercises": [
              { "exercise_id": "ex_004", "prescription_mode": "hypertrophy" },
              { "exercise_id": "ex_063", "prescription_mode": "hypertrophy" },
              { "exercise_id": "ex_041", "prescription_mode": "endurance" }
            ]
          }
        ]
      },
      "recovery": null,
      "throwing": "flat_ground_or_light_catch",
      "notes": "Second lower body session — slightly less volume than Day 2. Focus on movement quality."
    },
    "day_5": {
      "label": "Light Upper + Pre-Game Prep",
      "body_focus": "upper",
      "training_intent": "activation_maintenance",
      "lifting": {
        "duration_min": 25,
        "structure": "circuit",
        "blocks": [
          {
            "block_name": "Activation",
            "exercises": [
              { "exercise_id": "ex_036", "prescription_mode": "warmup" },
              { "exercise_id": "ex_028", "prescription_mode": "warmup" },
              { "exercise_id": "ex_029", "prescription_mode": "endurance" }
            ]
          },
          {
            "block_name": "Light Strength",
            "exercises": [
              { "exercise_id": "ex_020", "prescription_mode": "hypertrophy", "override": { "sets": 2, "intensity": "moderate" } },
              { "exercise_id": "ex_026", "prescription_mode": "hypertrophy", "override": { "sets": 2 } }
            ]
          },
          {
            "block_name": "Arm Care",
            "exercises": [
              { "exercise_id": "ex_041", "prescription_mode": "endurance" },
              { "exercise_id": "ex_032", "prescription_mode": "endurance" }
            ]
          }
        ]
      },
      "recovery": {
        "protocol": "pre_game_prep",
        "activities": [
          { "type": "mobility", "description": "Full body mobility flow — hips, T-spine, shoulders", "duration_min": 15 }
        ]
      },
      "throwing": "bullpen_day_or_sim",
      "notes": "Low volume, low intensity. Maintain movement patterns without accumulating fatigue. No new PRs."
    },
    "day_6": {
      "label": "Pre-Game Day — Rest/Mobility Only",
      "body_focus": "none",
      "training_intent": "none",
      "lifting": null,
      "recovery": {
        "protocol": "pre_game",
        "activities": [
          { "type": "mobility", "description": "Light dynamic stretching, band activation", "duration_min": 10 },
          { "type": "mental_prep", "description": "Visualization, scouting review", "duration_min": 15 },
          { "type": "nutrition", "description": "Carb load, hydration focus", "priority": "high" }
        ]
      },
      "throwing": "light_catch_only",
      "notes": "No lifting. Conserve energy. Early to bed."
    }
  },
  "global_rules": {
    "arm_feel_override": "If arm feel rating < 3 on any day, drop all upper body pressing and reduce pull volume by 50%. Add extra FPM and scapular work.",
    "recovery_override": "If WHOOP recovery < 33% (red), convert any strength day to a recovery/mobility day. If 33-66% (yellow), drop volume by ~30% but maintain intensity on compounds.",
    "progressive_overload": "Track working weights. If a pitcher hits all prescribed reps for 2 consecutive sessions, increase load by 5-10lbs on compounds, 2.5-5lbs on accessories.",
    "pull_push_ratio": "Maintain minimum 2:1 pull-to-push volume ratio across the week.",
    "fpm_frequency": "Pronator and wrist flexor work appears on minimum 4 of 7 days. Non-negotiable for UCL health."
  }
}
